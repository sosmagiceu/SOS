---
import OriginalHeader from '../components/OriginalHeader';
import OriginalFooter from '../components/OriginalFooter.astro';
import '../styles/tailwind-utilities.css';
import '../styles/original/shared.css';
interface Props { title: string; description?: string; page: string; }
const { title, page, description = 'Discover the S.O.S. Magic tarot deck and unlock your personal digital reading.' } = Astro.props;
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><meta name="description" content={description}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/><link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Grotesk:wght@300;400;600;700&family=Inter:wght@300;400;600&family=Cormorant+SC:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/><title>{title}</title></head><body data-page={page} class="bg-video-ready"><div class="bg-video-layer"><video class="bg-video" autoplay muted loop playsinline preload="auto" poster="https://sosmagic.b-cdn.net/Achterground%20enzo/Achtergrond%20.png" aria-hidden="true"><source src="https://sosmagic.b-cdn.net/Achterground%20enzo/Bubbles_.mp4" type="video/mp4"/></video></div><OriginalHeader client:load/><slot/><OriginalFooter/><script is:inline>const backgroundVideo=document.querySelector('.bg-video-layer video');if(backgroundVideo){const showVideo=()=>document.body.classList.add('bg-video-ready');const showFallback=()=>document.body.classList.remove('bg-video-ready');const playBackground=()=>backgroundVideo.play().then(showVideo).catch(()=>{});backgroundVideo.addEventListener('loadeddata',showVideo);backgroundVideo.addEventListener('canplay',playBackground);backgroundVideo.addEventListener('error',showFallback);window.addEventListener('pageshow',playBackground);document.addEventListener('visibilitychange',()=>{if(!document.hidden)playBackground()});playBackground();}</script></body></html>
