---
import OriginalHeader from '../components/OriginalHeader';
import OriginalFooter from '../components/OriginalFooter.astro';
import '../styles/tailwind-utilities.css';
import '../styles/original/shared.css';
interface Props { title: string; description?: string; page: string; }
const { title, page, description = 'Discover the S.O.S. Magic tarot deck and unlock your personal digital reading.' } = Astro.props;
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><meta name="description" content={description}/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/><link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Grotesk:wght@300;400;600;700&family=Inter:wght@300;400;600&family=Cormorant+SC:wght@400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/><title>{title}</title></head><body data-page={page}><div class="bg-video-layer original-mobile-video"><video class="bg-video" autoplay muted loop playsinline aria-hidden="true"><source src="https://sosmagic.b-cdn.net/Achterground%20enzo/Bubbles_.mp4" type="video/mp4"/></video></div><OriginalHeader client:load/><slot/><OriginalFooter/><script is:inline>const backgroundVideo=document.querySelector('.original-mobile-video video');if(backgroundVideo){backgroundVideo.addEventListener('play',()=>document.body.classList.add('bg-video-ready'));backgroundVideo.addEventListener('pause',()=>document.body.classList.remove('bg-video-ready'));}</script></body></html>
<style is:global>.original-mobile-video{display:none}@media(pointer:coarse){.original-mobile-video{display:block}}</style>
