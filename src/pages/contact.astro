---
import OriginalLayout from '../layouts/OriginalLayout.astro';
import '../styles/original/contact.css';
---
<OriginalLayout title="Contact – SOS Magic" page="contact">
<main class="contact-page">
    <section id="section-1" class="contact-section">
      <div class="contact-hero">
        <div class="contact-kicker">
          <h1 class="contact-title">
            <span class="contact-line" data-text="Contact us">Contact us</span>
          </h1>
        </div>

        <p class="contact-text">
          Most frequently asked questions can be found in our FAQ.
        </p>

        <div class="contact-actions">
          <a class="contact-cta" href="/faq">Go to FAQ</a>
        </div>

        <p class="contact-text contact-form-note">
          If you still have questions, fill in the form below to contact us.
        </p>
      </div>

      <form class="contact-form-card" id="contact-form" method="post" novalidate>
        <div class="contact-field-grid">
          <div class="contact-field">
            <label class="contact-label" for="contact-name">Name</label>
            <input class="contact-input" id="contact-name" name="name" type="text" placeholder="Your name" required/>
          </div>

          <div class="contact-field">
            <label class="contact-label" for="contact-email">Email</label>
            <input class="contact-input" id="contact-email" name="email" type="email" placeholder="Your email" required/>
          </div>
        </div>

        <div class="contact-field">
          <label class="contact-label" for="contact-subject">Subject</label>
          <input class="contact-input" id="contact-subject" name="subject" type="text" placeholder="Subject" required/>
        </div>

        <div class="contact-field">
          <label class="contact-label" for="contact-message">Message</label>
          <textarea class="contact-input contact-textarea" id="contact-message" name="message" placeholder="Your message" required></textarea>
        </div>

        <p class="contact-status" id="contact-status" aria-live="polite"></p>

        <button class="contact-cta contact-submit" id="contact-submit" type="submit">Send Message</button>
      </form>
    </section>
  </main>

<script is:inline src="/scripts/contact-page.js"></script>
</OriginalLayout>
