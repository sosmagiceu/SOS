---
import Layout from '../layouts/Layout.astro'; import PageHero from '../components/PageHero.astro'; import ContactForm from '../components/ContactForm';
---
<Layout title="Contact"><PageHero eyebrow="Contact us" title="How can we help?" intro="Have a quick question? You may find the answer in our frequently asked questions."/><section class="px-5 pb-28"><div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[.7fr_1.3fr]"><div><a href="/faq" class="inline-block rounded-full border border-white/15 px-6 py-3 font-bold hover:border-aqua">Go to FAQ</a><p class="mt-8 max-w-sm leading-7 text-white/55">If you still need help, send us a message and we will get back to you as soon as possible.</p><a href="mailto:support@sosmagic.eu" class="mt-5 block text-aqua">support@sosmagic.eu</a></div><ContactForm client:load/></div></section></Layout>
