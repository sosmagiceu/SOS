---
import Layout from '../layouts/Layout.astro'; import PageHero from '../components/PageHero.astro'; import Accordion from '../components/Accordion';
const steps=[{question:'Sign up as an Ambassador',answer:'<p>Simple registration takes just a couple of minutes.</p>'},{question:'Access ready-to-use materials',answer:'<p>Get instant access to free marketing assets and our “Effortless Sales” mini-course.</p>'},{question:'Earn stable, ethical income',answer:'<p>Receive your payouts without delays just by posting our ready videos!</p>'}];
---
<Layout title="Partnership"><PageHero eyebrow="Become an S.O.S. MAGIC Ambassador" title="Earn up to 30% per sale while helping others!"/><section class="px-5 pb-20"><div class="mx-auto max-w-5xl overflow-hidden rounded-[2rem] soft-ring"><video class="aspect-video w-full object-cover" src="https://sosmagic.b-cdn.net/videos/partnership.mov" poster="https://sosmagic.b-cdn.net/videos/partnership.jpg" controls playsinline preload="metadata"></video></div></section><section class="px-5 py-20"><div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[.8fr_1.2fr]"><h2 class="display text-6xl">3 Steps to Financial Freedom</h2><Accordion client:load items={steps}/></div></section><section class="px-5 pb-28 pt-16"><div class="mx-auto max-w-5xl text-center"><p class="eyebrow">Why now?</p><h2 class="display mt-5 text-5xl">Because This Is the Fastest-Growing Multi-Billion-Dollar Market!</h2><img src="https://sosmagic.b-cdn.net/videos/graph.png" alt="Growth market graph" class="mx-auto mt-10 rounded-[2rem] soft-ring"/><h3 class="display mt-14 text-4xl">Join the S.O.S. MAGIC Unique Partnership Program!</h3><a href="/contact" class="mt-8 inline-block rounded-full bg-white px-7 py-3.5 font-bold text-ink hover:bg-aqua">Become an Ambassador</a><p class="mt-8 leading-7 text-white/60">You don't need to “sell” aggressively.<br/>Simply share S.O.S. MAGIC ready-made content or film your own!</p></div></section></Layout>
