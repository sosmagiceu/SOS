---
import Layout from '../layouts/Layout.astro'; import PageHero from '../components/PageHero.astro';
const products = [
 {label:'THE S.O.S. MAGIC COLLECTION',title:'Your Full Support Cycle.',body:'Why fix only one part of your life? These three instruments guide you through decisions, emotions, and everyday moments, creating a complete cycle of support and a total upgrade for your reality.',image:'https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2021%2012%2014.jpg',alt:'The S.O.S. Magic Collection',cta:'Get the full set',url:'https://payhip.com/b/lIR71'},
 {label:'Tarot “SINK or SWIM”',title:'Clarity & Right Direction.',body:'It pulls you out of the mental spiral into a calmer inner space. Simple direct guidance for when your thoughts feel tangled and you need to know your next move.',image:'https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2019%2058%2038.jpg',alt:'Tarot Sink or Swim deck',cta:'Explore Sink or Swim',url:'https://payhip.com/b/wyrex'},
 {label:'Oracle “ENCHANTED DEPTHS”',title:'Deep Emotions & Positive Patterns.',body:'Slow down to notice the emotional undercurrents you couldn’t quite name. It illuminates hidden truths so you can move with more awareness and ease.',image:'https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2020%2050%2041.jpg',alt:'Oracle Enchanted Depths deck',cta:'Explore Enchanted Depths',url:'https://payhip.com/b/dkWpi'},
 {label:'Angelic Messages “MYSTICHARMS”',title:'Daily Comfort & Clear Signs.',body:'Soft supportive messages that remind you that you are supported. Shift your mindset and find peace in the present moment with gentle guidance.',image:'https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2020%2044%2050.jpg',alt:'Mysticharms deck',cta:'Explore Mysticharms',url:'https://payhip.com/b/S7zDl'}
];
---
<Layout title="Products"><PageHero eyebrow="Products" title="Three Master Editions. Three exclusive tools." intro="Every woman needs different support on different days. Discover the three Master Editions of the S.O.S. Magic Collection."/><section class="px-5 pb-24"><div class="mx-auto max-w-5xl overflow-hidden rounded-[2rem] soft-ring"><video class="aspect-video w-full object-cover" src="https://sosmagic.b-cdn.net/videos/collection.mp4" poster="https://sosmagic.b-cdn.net/videos/collection.png" controls playsinline preload="metadata"></video></div><p class="mx-auto mt-8 max-w-xl text-center leading-8 text-white/60">Each Edition includes<br/>• A Complete Digital Interpretation Book<br/>• A complimentary exclusive Neon Deck</p></section><section class="px-5 pb-28"><div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-2">{products.map(product => <article class="glass overflow-hidden rounded-[2rem]"><img src={product.image} alt={product.alt} loading="lazy" class="aspect-[4/3] w-full object-cover"/><div class="p-7 sm:p-9"><p class="eyebrow">{product.label}</p><h2 class="display mt-4 text-4xl">{product.title}</h2><p class="mt-5 leading-7 text-white/60">{product.body}</p><a class="mt-7 inline-block rounded-full bg-white px-6 py-3 font-bold text-ink hover:bg-aqua" href={product.url} target="_blank" rel="noopener noreferrer">{product.cta}</a></div></article>)}</div></section></Layout>
