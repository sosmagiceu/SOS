---
import OriginalLayout from '../layouts/OriginalLayout.astro';
import '../styles/original/collection.css';
---
<OriginalLayout title="Products – SOS Magic" page="collection">
<main class="collection-page">

    <!-- HERO + VIDEO -->
    <section id="section-1" class="collection-section">
      <div class="collection-kicker">
        <span class="collection-line-mid" data-text="PRODUCTS">PRODUCTS</span>
      </div>

      <h1 class="collection-title">Three Master Editions. Three exclusive tools.</h1>

      <div class="collection-video" aria-label="Collection video">
        <div class="collection-video-shell">
          <video class="collection-player"
                 src="https://sosmagic.b-cdn.net/videos/collection.mp4"
                 poster="https://sosmagic.b-cdn.net/videos/collection.png"
                 controls
                 playsinline
                 preload="metadata" aria-label="Page introduction video">
          </video>
        </div>
      </div>

      <p class="collection-text">
        Every woman needs different support on different days.
        <br/><br/>
        Discover the 3 Master Editions of the S.O.S. MAGIC Collection.
        <br/><br/>
        Each Edition includes<br/>
        • A Complete Digital Interpretation Book<br/>
        • A complimentary exclusive Neon Deck
      </p>
    </section>

            <div class="collection-divider" aria-hidden="true"></div>

    <!-- EDITIONS -->
    <section id="section-2" class="collection-section">
      <div class="collection-cards">

        <!-- 1 -->
        <article class="collection-card">
          <div class="collection-deck-head">
            <div class="collection-kicker">
              <span class="collection-line-mid" data-text="THE S.O.S. MAGIC COLLECTION">THE S.O.S. MAGIC COLLECTION</span>
            </div>
            <h3 class="collection-deck-title">Your Full Support Cycle.</h3>
          </div>
          <p class="collection-text">
            Why fix only one part of your life? These three instruments guide you through decisions, emotions, and everyday moments,
            creating a complete cycle of support and a total upgrade for your reality.
          </p>

          <div class="collection-deck-image">
            <img src="https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2021%2012%2014.jpg" alt="The S.O.S. Magic Collection" loading="eager">
          </div>

          <a class="collection-cta" href="/buy/collection">Get the full set</a>
        </article>

        <div class="collection-divider" aria-hidden="true"></div>

        <!-- 2 -->
        <article class="collection-card">
          <div class="collection-deck-head">
            <div class="collection-kicker">
              <span class="collection-line-mid" data-text="Tarot “SINK or SWIM”">Tarot “SINK or SWIM”</span>
            </div>
            <h3 class="collection-deck-title">Clarity &amp; Right Direction.</h3>
          </div>
          <p class="collection-text">
            It pulls you out of the mental spiral into a calmer inner space.
            Simple direct guidance for when your thoughts feel tangled and you need to know your next move.
          </p>

          <div class="collection-deck-image">
            <img src="https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2019%2058%2038.jpg" alt="Tarot Sink or Swim deck" loading="eager">
          </div>

          <a class="collection-cta" href="/buy/tarot-deck">Explore Sink or Swim</a>
        </article>

        <div class="collection-divider" aria-hidden="true"></div>

        <!-- 3 -->
        <article class="collection-card">
          <div class="collection-deck-head">
            <div class="collection-kicker">
              <span class="collection-line-mid" data-text="Oracle “ENCHANTED DEPTHS”">Oracle “ENCHANTED DEPTHS”</span>
            </div>
            <h3 class="collection-deck-title">Deep Emotions &amp; Positive Patterns.</h3>
          </div>
          <p class="collection-text">
            Slow down to notice the emotional undercurrents you couldn’t quite name.
            It illuminates hidden truths so you can move with more awareness and ease.
          </p>

          <div class="collection-deck-image">
            <img src="https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2020%2050%2041.jpg" alt="Oracle Enchanted Depths deck" loading="eager">
          </div>

          <a class="collection-cta" href="/buy/enchanted-depths">Explore Enchanted Depths</a>
        </article>

        <div class="collection-divider" aria-hidden="true"></div>

        <!-- 4 -->
        <article class="collection-card">
          <div class="collection-deck-head">
            <div class="collection-kicker">
              <span class="collection-line-mid" data-text="Angelic Messages “MYSTICHARMS”">Angelic Messages “MYSTICHARMS”</span>
            </div>
            <h3 class="collection-deck-title">Daily Comfort &amp; Clear Signs.</h3>
          </div>
          <p class="collection-text">
            Soft supportive messages that remind you that you are supported.
            Shift your mindset and find peace in the present moment with gentle guidance.
          </p>

          <div class="collection-deck-image">
            <img src="https://sosmagic.b-cdn.net/fotos/Photo%2006-03-2026%2C%2020%2044%2050.jpg" alt="Mysticharms deck" loading="eager">
          </div>

          <a class="collection-cta" href="/buy/mysticharms">Explore Mysticharms</a>
        </article>

      </div>
    </section>

  </main>

</OriginalLayout>
