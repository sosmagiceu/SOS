---
import OriginalLayout from '../layouts/OriginalLayout.astro';
import '../styles/original/home.css';
---
<OriginalLayout title="Home – SOS Magic" page="home">
<section class="content-section features-section-bg" id="features">
  <div class="container">

    <h2 class="section-title">
      <span class="title-swap" aria-label="SOS Magic Presents">
        <span class="sos-title sos-title--text">Presents...</span>
        <span class="sos-title-logo-wrap">
          <img class="sos-title-logo" src="https://sosmagic.b-cdn.net/Achterground%20enzo/Logo%20.png" alt="SOS Magic" loading="eager" decoding="async" aria-hidden="true">
        </span>
      </span>
    </h2>

    <div class="features-container">
      <div class="carousel-3d" id="carousel">

        <!-- CARD 1 -->
        <div class="feature-card-3d" data-index="0">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/1.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">01</span>
            <h3 class="feature-title-3d">Products</h3>
            <p class="feature-description-3d">
              Take a look at what S.O.S. Magic offers.
            </p>
            <a class="guide-btn" href="/products">Learn More</a>
          </div>
        </div>

        <!-- CARD 2 -->
        <div class="feature-card-3d" data-index="1">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/2.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">02</span>
            <h3 class="feature-title-3d">Method</h3>
            <p class="feature-description-3d">
              Find out how the S.O.S. Magic method works.
            </p>
            <a class="guide-btn" href="/method">Learn More</a>
          </div>
        </div>

        <!-- CARD 3 -->
        <div class="feature-card-3d" data-index="2">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/3.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">03</span>
            <h3 class="feature-title-3d">FAQ</h3>
            <p class="feature-description-3d">
              Helpful answers to common questions.
            </p>
            <a class="guide-btn" href="/faq">Learn More</a>
          </div>
        </div>

        <!-- CARD 4 -->
        <div class="feature-card-3d" data-index="3">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/4.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">04</span>
            <h3 class="feature-title-3d">Our Story</h3>
            <p class="feature-description-3d">
              Find out where and why we started.
            </p>
            <a class="guide-btn" href="/story">Learn More</a>
          </div>
        </div>

        <!-- CARD 5 -->
        <div class="feature-card-3d" data-index="4">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/5.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">05</span>
            <h3 class="feature-title-3d">Guided Reading</h3>
            <p class="feature-description-3d">
              Clear insight for your current situation.
            </p>
            <a class="guide-btn" href="/guided-reading">Learn More</a>
          </div>
        </div>

        <!-- CARD 6 -->
        <div class="feature-card-3d" data-index="5">
          <img class="carousel-card-image" src="https://sosmagic.b-cdn.net/carrousel%20fotos/6.png" alt="" aria-hidden="true">
          <div class="feature-card-content">
            <span class="feature-number">06</span>
            <h3 class="feature-title-3d">Partnership</h3>
            <p class="feature-description-3d">
              Want to collaborate with us?
            </p>
            <a class="guide-btn" href="/partnership">Learn More</a>
          </div>
        </div>

      </div>

      <div class="carousel-controls">
        <button class="carousel-btn" id="prevBtn" type="button" aria-label="Previous card">◀</button>
        <button class="carousel-btn" id="nextBtn" type="button" aria-label="Next card">▶</button>
      </div>

    </div>
  </div>
</section>

<script is:inline src="/scripts/home-carousel.js" defer></script>
</OriginalLayout>
