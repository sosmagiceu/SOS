---
import OriginalLayout from '../layouts/OriginalLayout.astro';
import '../styles/original/contact.css';
---
<OriginalLayout title="Page not found – SOS Magic" page="contact">
  <main class="contact-page">
    <section class="contact-section">
      <div class="contact-hero">
        <div class="contact-kicker">
          <h1 class="contact-title"><span class="contact-line" data-text="Page not found">Page not found</span></h1>
        </div>
        <p class="contact-text">The page you requested does not exist.</p>
        <div class="contact-actions"><a class="contact-cta" href="/">Back home</a></div>
      </div>
    </section>
  </main>
</OriginalLayout>
