---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/8 bg-black/20 px-5 py-12">
  <div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[1fr_auto] md:items-end">
    <div>
      <p class="eyebrow">Emotional first aid</p>
      <h2 class="display mt-3 max-w-xl text-4xl">A clearer mind starts with one honest moment.</h2>
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-white/55">
      <a href="/terms" class="hover:text-white">Terms & privacy</a>
      <a href="mailto:support@sosmagic.eu" class="hover:text-white">support@sosmagic.eu</a>
      <span>© {year} S.O.S. Magic</span>
    </div>
  </div>
</footer>
