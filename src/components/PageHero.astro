---
interface Props { eyebrow: string; title: string; intro?: string; }
const { eyebrow, title, intro } = Astro.props;
---
<section class="px-5 pb-14 pt-36 lg:pb-20 lg:pt-44"><div class="mx-auto max-w-7xl"><p class="eyebrow">{eyebrow}</p><h1 class="display gradient-text mt-6 max-w-5xl text-6xl sm:text-7xl lg:text-8xl">{title}</h1>{intro && <p class="mt-8 max-w-2xl text-lg leading-8 text-white/60">{intro}</p>}</div></section>
